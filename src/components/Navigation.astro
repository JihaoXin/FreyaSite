---
import { NAV } from '../i18n/ui';
import { localePath, type Lang } from '../i18n/utils';

interface Props {
    lang: Lang;
}
const { lang } = Astro.props;

// Work out which nav item is active by comparing the current route remainder.
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
let rest = Astro.url.pathname.startsWith(base)
    ? Astro.url.pathname.slice(base.length)
    : Astro.url.pathname.replace(/^\/+/, '');
rest = rest.replace(/^zh\//, '').replace(/^zh$/, '');

const links = NAV.map((item) => ({
    label: item[lang],
    href: localePath(lang, item.slug),
    active: rest === item.slug,
}));
---

<div id="main-menu" class="navigation">
    <button class="menu-close" aria-label="Close Menu">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>
    <div class="nav-links">
        {links.map((link) => (
            <a href={link.href} aria-current={link.active ? 'page' : undefined}>{link.label}</a>
        ))}
    </div>
</div>
