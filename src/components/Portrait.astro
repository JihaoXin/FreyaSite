---
import { Image } from 'astro:assets';
import portrait from '../assets/portrait.jpg';

interface Props {
    size?: number;
    class?: string;
    alt?: string;
}
const { size = 180, class: className, alt = 'Freya Zhang' } = Astro.props;
const dim = Math.round(size * 2); // render at 2x for crisp display on retina screens
---

<Image
    src={portrait}
    alt={alt}
    width={dim}
    height={dim}
    class:list={['portrait-photo', className]}
    style={`width:${size}px;height:${size}px;`}
    loading="eager"
/>

<style>
    .portrait-photo {
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
        flex: 0 0 auto;
    }
</style>
