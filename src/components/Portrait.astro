---
// Placeholder monogram avatar, used until a real photo is supplied.
// To use a real photo instead: drop a square image at src/assets/portrait.jpg
// and replace this component's markup with an <Image> from astro:assets.
interface Props {
    size?: number;
    class?: string;
    initials?: string;
}
const { size = 180, class: className, initials = 'FZ' } = Astro.props;
---

<div
    class:list={['portrait-monogram', className]}
    style={`width:${size}px;height:${size}px;font-size:${Math.round(size * 0.38)}px;`}
    aria-hidden="true"
>
    <span>{initials}</span>
</div>

<style>
    .portrait-monogram {
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: #fff;
        background: linear-gradient(
            135deg,
            var(--color-accent-base) 0%,
            color-mix(in oklch, var(--color-accent-base) 60%, #0b5563) 100%
        );
        box-shadow: 0 10px 30px rgba(13, 148, 136, 0.25);
        user-select: none;
        flex: 0 0 auto;
    }
    .portrait-monogram span {
        transform: translateY(-1px);
    }
</style>
