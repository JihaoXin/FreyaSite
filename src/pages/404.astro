---
import Layout from '../layouts/Layout.astro';
import { localePath } from '../i18n/utils';
---

<Layout lang="en" pageTitle="404">
    <div class="page-container notfound">
        <h1>404</h1>
        <p class="notfound-msg">Sorry, this page doesn’t exist. / 抱歉，页面不存在。</p>
        <p>
            <a href={localePath('en', '')}>Go home</a>
            <span class="sep">·</span>
            <a href={localePath('zh', '')}>返回首页</a>
        </p>
    </div>
</Layout>

<style>
    .notfound {
        text-align: center;
        padding-top: 3rem;
    }
    .notfound-msg {
        font-size: 1.1rem;
        color: var(--color-text-muted);
        margin-bottom: 1.5rem;
    }
    .sep {
        margin: 0 0.6rem;
        color: var(--color-text-muted);
    }
</style>
